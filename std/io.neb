namespace std::io;
use std::primitives;

tag { str, T: Stringable } as Printable;

trait Stringable {
    str toStr();
}

extern "C" {
    void __nebula_rt_print(keeps Ref<u8> buf);
    void __nebula_rt_println(keeps Ref<u8> buf);
}

// Generic print that works for anything Stringable
void print<T: Printable>(T item) => __nebula_rt_print(item.toStr().ptr)

// Generic println that works for anything Stringable
void println<T: Printable>(T item) => __nebula_rt_println(item.toStr().ptr)