namespace std::strings;

// =============================================================================
// FFI — C runtime string operations  (implemented in runtime/core/strings.c)
// =============================================================================

private extern "C"
{
    i64 neb_str_len(keeps str s);
    i32 neb_str_char_at(keeps str s, i64 index);
    i64 neb_str_index_of_char(keeps str s, i32 ch, i64 start);
    i64 neb_str_index_of(keeps str haystack, keeps str needle, i64 start);
    i64 neb_str_last_index_of_char(keeps str s, i32 ch);
    str neb_str_substring(keeps str s, i64 start, i64 len);
    str neb_str_slice(keeps str s, i64 start, i64 end);
    i32 neb_str_starts_with(keeps str s, keeps str prefix);
    i32 neb_str_ends_with(keeps str s, keeps str suffix);
    i32 neb_str_contains(keeps str haystack, keeps str needle);
    str neb_str_to_lower(keeps str s);
    i32 neb_str_equals(keeps str a, keeps str b);
    i32 neb_str_equals_ignore_case(keeps str a, keeps str b);
    i64 neb_str_parse_i64(keeps str s);
    str neb_str_concat2(keeps str a, keeps str b);
    str neb_str_concat3(keeps str a, keeps str b, keeps str c);
    str neb_str_trim(keeps str s);
}

// =============================================================================
// Free-standing wrappers  (backward compat + std::strings::indexOf(...) access)
// =============================================================================

i64 indexOf(keeps str haystack, keeps str needle, i64 start)
{
    return neb_str_index_of(haystack, needle, start);
}

i64 indexOfChar(keeps str haystack, i32 ch, i64 start)
{
    return neb_str_index_of_char(haystack, ch, start);
}

// =============================================================================
// StringUtils — ergonomic method-based API for the str type
// =============================================================================

trait StringUtils
{
    // -- Query ----------------------------------------------------------------
    i64 length();
    i32 charAt(i64 index);

    // -- Searching ------------------------------------------------------------
    i64 indexOf(str needle, i64 start);
    i64 indexOfChar(i32 ch, i64 start);
    i64 lastIndexOfChar(i32 ch);

    // -- Extraction -----------------------------------------------------------
    str substring(i64 start, i64 length);
    str slice(i64 start, i64 end);

    // -- Predicates -----------------------------------------------------------
    bool startsWith(str prefix);
    bool endsWith(str suffix);
    bool contains(str needle);
    bool equals(str other);
    bool equalsIgnoreCase(str other);

    // -- Transformation -------------------------------------------------------
    str toLower();
    str trim();

    // -- Parsing --------------------------------------------------------------
    i64 parseI64();

    // -- Building -------------------------------------------------------------
    str concat(str other);
    str concat3(str b, str c);
}

// =============================================================================
// Implementation — wires each method to its C runtime counterpart
// =============================================================================

impl StringUtils for str
{
    // -- Query ----------------------------------------------------------------
    i64 length() => neb_str_len(this)
    i32 charAt(i64 index) => neb_str_char_at(this, index)

    // -- Searching ------------------------------------------------------------
    i64 indexOf(str needle, i64 start) => neb_str_index_of(this, needle, start)
    i64 indexOfChar(i32 ch, i64 start) => neb_str_index_of_char(this, ch, start)
    i64 lastIndexOfChar(i32 ch) => neb_str_last_index_of_char(this, ch)

    // -- Extraction -----------------------------------------------------------
    str substring(i64 start, i64 length) => neb_str_substring(this, start, length)
    str slice(i64 start, i64 end) => neb_str_slice(this, start, end)

    // -- Predicates -----------------------------------------------------------
    bool startsWith(str prefix) => neb_str_starts_with(this, prefix) != 0
    bool endsWith(str suffix) => neb_str_ends_with(this, suffix) != 0
    bool contains(str needle) => neb_str_contains(this, needle) != 0
    bool equals(str other) => neb_str_equals(this, other) != 0
    bool equalsIgnoreCase(str other) => neb_str_equals_ignore_case(this, other) != 0

    // -- Transformation -------------------------------------------------------
    str toLower() => neb_str_to_lower(this)
    str trim() => neb_str_trim(this)

    // -- Parsing --------------------------------------------------------------
    i64 parseI64() => neb_str_parse_i64(this)

    // -- Building -------------------------------------------------------------
    str concat(str other) => neb_str_concat2(this, other)
    str concat3(str b, str c) => neb_str_concat3(this, b, c)
}
